{
  "name": "@finboard/banking-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "PORT=4005 nodemon --env-file ../../.env src/server.js",
    "start": "node --env-file ../../.env src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "pnpm prisma:generate && prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "test": "BANK_DATABASE_URL=postgresql://finboard:finboard_pass@localhost:5432/finboard_banking_test NODE_OPTIONS='--experimental-vm-modules' jest --forceExit --runInBand",
    "test:coverage": "BANK_DATABASE_URL=postgresql://finboard:finboard_pass@localhost:5432/finboard_banking_test NODE_OPTIONS='--experimental-vm-modules' jest --coverage --forceExit --runInBand"
  },
  "dependencies": {
    "@finboard/config": "workspace:*",
    "@finboard/contracts": "workspace:*",
    "@finboard/kafka": "workspace:*",
    "@finboard/service-kit": "workspace:*",
    "@finboard/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2"
  }
}
